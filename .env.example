# Copy to .env and fill in. .env is gitignored.

# HTTP server
PORT=3000

# Postgres connection string. Locally, point to the docker-compose service:
#   DATABASE_URL=postgres://algolens:dev@localhost:5433/algolens
# In Render, this is auto-injected from the linked Postgres service.
DATABASE_URL=postgres://algolens:dev@localhost:5433/algolens

# Signing key for the JWT session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me

# Optional Go gRPC ranker. Leave unset to skip; Node BM25 is the default.
# GRPC_BM25_ADDR=127.0.0.1:50051

# Optional default ranker. One of: tfidf, bm25, bm25-grpc.
# RANKER=bm25
