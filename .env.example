# Copy to .env and fill in. .env is gitignored.

# HTTP server
PORT=3000

# Postgres. Default dev path is Neon (hosted, free tier, data persists across
# laptop restarts). Paste the pooled connection string from the Neon console —
# it already includes `sslmode=require`, which the app uses to flip on SSL.
#
# Offline / docker fallback:
#   1) npm run services:start   (boots local postgres in docker on :5433)
#   2) DATABASE_URL=postgres://algolens:dev@localhost:5433/algolens
# Quote the URL — Neon strings contain `&`, which would break bash sourcing.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Signing key for the JWT session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me

# Optional Go gRPC ranker. Leave unset to skip; Node BM25 is the default.
# GRPC_BM25_ADDR=127.0.0.1:50051

# Optional default ranker. One of: tfidf, bm25, bm25-grpc.
# RANKER=bm25
